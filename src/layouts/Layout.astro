---
import { ClientRouter } from "astro:transitions";
import Analytics from "@vercel/analytics/astro";
import Navigation from "../components/Navigation";
import "../styles/index.css";

const DEFAULT_DESCRIPTION =
  "한국인의 정체성과 긍지를 지닌 이중문화와 이중언어의 소유자로서 따뜻한 인성과 지성을 지닌 창의적 인재를 키우는 것을 목표로 하고 있습니다.";
const SITE = "뉴질랜드 한민족 한글학교";

interface Props {
  title: string;
  description?: string;
  canonical?: string;
  transparentNav?: boolean;
}

const {
  title,
  description = DEFAULT_DESCRIPTION,
  canonical = "https://www.nzsok.school.nz/",
  transparentNav = false,
} = Astro.props;
---

<!doctype html>
<html lang="ko">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="icon" type="image/png" sizes="32x32" href="/favicon-32x32.png" />
    <link rel="icon" type="image/png" sizes="16x16" href="/favicon-16x16.png" />
    <link rel="apple-touch-icon" href="/apple-touch-icon.png" />
    <meta property="og:type" content="website" />
    <meta property="og:site_name" content={SITE} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content="https://www.nzsok.school.nz/logo.png" />
    <meta property="og:url" content={canonical} />
    <link rel="canonical" href={canonical} />
    <link rel="preconnect" href="https://cdn.jsdelivr.net" crossorigin />
    <script
      is:inline
      type="module"
      src="https://w.behold.so/widget.js"></script>
    <ClientRouter />
  </head>
  <body>
    <Navigation client:load transparent={transparentNav} />
    <slot />
    <Analytics />
  </body>
</html>
