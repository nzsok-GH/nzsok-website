---
import Layout from "../layouts/Layout.astro";
import SectionTabs from "../components/SectionTabs";
import EnrolContent from "../components/EnrolContent";
import Footer from "../components/Footer.astro";

const SECTIONS = [
  { id: "grade", label: "학년 안내" },
  { id: "procedure", label: "등록 절차" },
  { id: "tuition", label: "학비" },
  { id: "contact", label: "입학 문의" },
];
---

<Layout
  title="입학안내 | 뉴질랜드 한민족 한글학교"
>
  <SectionTabs client:load tabs={SECTIONS} />

  <main class="enrol-main">
    <h1 class="sr-only">입학안내</h1>
    <EnrolContent />
  </main>

  <Footer />
</Layout>
