---
import Layout from "../layouts/Layout.astro";
import SectionTabs from "../components/SectionTabs";
import EducationSections from "../components/EducationSections";
import ClassDojoSection from "../components/ClassDojoSection";
import Footer from "../components/Footer.astro";

const SECTIONS = [
  { id: "schedule", label: "시간표" },
  { id: "programs", label: "커리큘럼" },
  { id: "annual", label: "연간 교육계획" },
  { id: "classdojo", label: "클래스도조" },
];
---

<Layout
  title="교육 | 뉴질랜드 한민족 한글학교"
>
  <SectionTabs client:load tabs={SECTIONS} />

  <main class="education-main">
    <h1 class="sr-only">교육</h1>
    <EducationSections />
    <ClassDojoSection client:visible />
  </main>

  <Footer />
</Layout>
