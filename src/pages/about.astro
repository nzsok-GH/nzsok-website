---
import Layout from "../layouts/Layout.astro";
import SectionTabs from "../components/SectionTabs";
import { AboutIntroSong, AboutBoardStaffCampus } from "../components/AboutSections";
import CampusSection from "../components/CampusSection";
import HistorySection from "../components/HistorySection";
import Footer from "../components/Footer.astro";

const SECTIONS = [
  { id: "intro", label: "소개글" },
  { id: "song", label: "교가" },
  { id: "history", label: "연혁" },
  { id: "board", label: "이사회" },
  { id: "staff", label: "교직원" },
  { id: "campus", label: "Sherwood School" },
];
---

<Layout
  title="학교소개 | 뉴질랜드 한민족 한글학교"
  description="1997년 설립된 뉴질랜드 한민족 한글학교의 연혁, 교가, 이사회·교직원과 Sherwood School 캠퍼스를 소개합니다."
>
  <SectionTabs client:load tabs={SECTIONS} />

  <main class="about-main">
    <h1 class="sr-only">학교소개</h1>
    <AboutIntroSong />
    <HistorySection client:visible />
    <AboutBoardStaffCampus />
    <CampusSection client:visible />
  </main>

  <Footer />
</Layout>
