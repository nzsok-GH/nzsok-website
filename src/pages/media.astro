---
import Layout from "../layouts/Layout.astro";
import Footer from "../components/Footer.astro";

const H2 =
  "font-family:'SUIT',sans-serif;font-size:clamp(24px,3vw,36px);font-weight:700;color:#1c2b3a;line-height:1.3";
---

<Layout
  title="알림마당 | 뉴질랜드 한민족 한글학교"
  description="뉴질랜드 한민족 한글학교의 소식과 행사 사진을 인스타그램(@nzsok.official)에서 소개합니다."
>
  <main class="media-main">
    <h1 class="sr-only">알림마당</h1>
    <section id="instagram">
      <div class="flex flex-col mb-8" style="gap:12px">
        <h2 style={H2}>인스타그램</h2>
        <div class="flex justify-end pb-8" style="margin-bottom:28px">
          <a
            href="https://www.instagram.com/nzsok.official"
            target="_blank"
            rel="noopener noreferrer"
            class="ig-link flex items-center gap-1.5 no-underline"
            style="font-size:15px;font-weight:600;color:#9278D6"
          >
            @nzsok.official
            <svg
              width="14"
              height="14"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="2.5"
              stroke-linecap="round"
              stroke-linejoin="round"
            >
              <path d="M7 17L17 7M17 7H7M17 7v10"></path>
            </svg>
          </a>
        </div>
      </div>
      <behold-widget feed-id="hXTPq6t7GL3vE8tNJ5vN"></behold-widget>
    </section>
  </main>

  <Footer />
</Layout>

<style>
  .ig-link {
    transition: opacity 0.2s;
  }
  .ig-link:hover {
    opacity: 0.7;
  }
</style>
