---
import Layout from "../layouts/Layout.astro";

const LINKS = [
  ["/about", "학교소개"],
  ["/education", "교육"],
  ["/media", "알림마당"],
  ["/enrol", "입학안내"],
];
---

<Layout
  title="페이지를 찾을 수 없습니다 | 뉴질랜드 한민족 한글학교"
  bare
>
  <main class="notfound-main">
    <h1 class="notfound-title">페이지를 찾을 수 없습니다</h1>

    <p class="notfound-text">
      요청하신 페이지가 존재하지 않거나 주소가 변경되었습니다.
    </p>

    <a href="/" class="btn-primary notfound-home">홈으로 돌아가기</a>

    <nav class="notfound-links" aria-label="바로가기">
      {LINKS.map(([href, label]) => <a href={href}>{label}</a>)}
    </nav>
  </main>
</Layout>

<style>
  .notfound-main {
    min-height: 100vh;
    max-width: 1200px;
    margin: 0 auto;
    padding: 80px 48px;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    text-align: center;
  }
  .notfound-title {
    font-family: "SUIT", sans-serif;
    font-size: clamp(24px, 3vw, 36px);
    font-weight: 700;
    color: #1c2b3a;
    line-height: 1.3;
    margin-bottom: 16px;
  }
  .notfound-text {
    font-size: 16px;
    line-height: 1.8;
    color: #4a5f75;
    margin-bottom: 32px;
  }
  .notfound-home {
    display: inline-block;
    padding: 12px 28px;
    border-radius: 999px;
    font-family: "SUIT", sans-serif;
    font-size: 15px;
    font-weight: 700;
    text-decoration: none;
  }
  .notfound-links {
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    gap: 8px 28px;
    margin-top: 40px;
    padding-top: 28px;
    border-top: 1px solid #ede4d3;
    width: 100%;
    max-width: 520px;
  }
  .notfound-links a {
    font-size: 15px;
    font-weight: 500;
    color: #4a5f75;
    text-decoration: none;
    transition: color 0.2s;
  }
  .notfound-links a:hover {
    color: #9278d6;
  }
  @media (max-width: 767px) {
    .notfound-main {
      padding: 60px 20px;
    }
  }
</style>
